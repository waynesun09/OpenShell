# Copy to .env and fill in NVIDIA_API_KEY. Loaded automatically by the proxy/MCP.
NVIDIA_API_KEY=your-nvapikey
ENV_FILE=.env

# Public upstream the proxy forwards to when an image is NOT redacted.
# This is what inference.local resolves to from the sandbox.
UPSTREAM_BASE_URL=https://inference-api.nvidia.com
UPSTREAM_MODEL=openai/openai/gpt-5.5

# Private/local model the MCP `call_inference` tool calls (e.g. LM Studio).
PRIVATE_UPSTREAM_BASE_URL=http://localhost:1234
PRIVATE_UPSTREAM_MODEL=nvidia/nemotron-3-nano-omni
PRIVATE_UPSTREAM_API_KEY=
MCP_FORCE_UPSTREAM_MODEL=true

# Bind to 0.0.0.0 so the podman/VM-hosted sandbox can reach the host via
# host.openshell.internal.
PROXY_HOST=0.0.0.0
PROXY_PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_TRANSPORT=http

PROXY_LOG_LEVEL=INFO
REQUEST_LOG_DIR=request-logs

# Demo magic: the proxy reads this OpenShell-style policy file on every request
# and redacts images only when content_policy.content_type.image == redact.
# (REDACTION_ENABLED is the fallback when CONTENT_POLICY_FILE is unset.)
CONTENT_POLICY_FILE=../policies/content-policy.yaml
REDACTION_ENABLED=false

# Store redacted images so the MCP can re-load them via image_reference.
STORE_REDACTED_IMAGES=true
REDACTED_IMAGE_DIR=/tmp/redact-spike-images
