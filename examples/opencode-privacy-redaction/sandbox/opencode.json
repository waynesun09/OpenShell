{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "model": "inference-local/openai/openai/gpt-5.5",
  "small_model": "inference-local/openai/openai/gpt-5.5",
  "provider": {
    "inference-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenShell inference.local",
      "options": {
        "baseURL": "https://inference.local/v1",
        "apiKey": "dummy"
      },
      "models": {
        "openai/openai/gpt-5.5": {
          "name": "gpt-5.5 (inference.local)",
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "local_model": {
      "type": "remote",
      "url": "http://host.openshell.internal:8001/mcp",
      "enabled": true,
      "oauth": false
    }
  }
}
